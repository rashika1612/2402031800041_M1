    <body>
        <ol>
            <li>Item one</li>
            <li>
                Item two
                <ol type="l">
                    <li>Sublist item one</li>
                    <li>
                        Sublist item two
                        <ol type="i">
                            <li>Sub-sub list item one</li>
                            <li>
                                Sub-sub list item two
                                <ol type="A">
                                    <li>Sub-sub-sub list item one</li>
                                    <li>
                                        Sub-sub-sub list item two
                                        <ol type="a">
                                            <li>Sub-sub-subs list item one</li>
                                            <li>Sub-sub-subs list item two</li>
                                        </ol>
                                    </li>
